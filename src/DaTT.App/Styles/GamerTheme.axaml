<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Styles.Resources>
    <SolidColorBrush x:Key="AppBg" Color="#1E1E1E" />
    <SolidColorBrush x:Key="SidebarBg" Color="#252526" />
    <SolidColorBrush x:Key="PanelBg" Color="#1E1E1E" />
    <SolidColorBrush x:Key="PanelSoftBg" Color="#2D2D30" />
    <SolidColorBrush x:Key="PanelBorder" Color="#3E3E42" />
    <SolidColorBrush x:Key="ActivityBarBg" Color="#333333" />
    <SolidColorBrush x:Key="TabBarBg" Color="#252526" />
    <SolidColorBrush x:Key="TabActiveBg" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TabActiveBorder" Color="#007ACC" />
    <SolidColorBrush x:Key="InputBg" Color="#3C3C3C" />
    <SolidColorBrush x:Key="InputBorder" Color="#4E4E52" />
    <SolidColorBrush x:Key="AccentBlue" Color="#007ACC" />
    <SolidColorBrush x:Key="AccentGreen" Color="#4EC9B0" />
    <SolidColorBrush x:Key="TextPrimary" Color="#D4D4D4" />
    <SolidColorBrush x:Key="TextMuted" Color="#808080" />
    <SolidColorBrush x:Key="TextBright" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Danger" Color="#F44747" />
    <SolidColorBrush x:Key="Warning" Color="#CCA700" />
    <SolidColorBrush x:Key="SelectionBg" Color="#094771" />
    <SolidColorBrush x:Key="HoverBg" Color="#2A2D2E" />
    <SolidColorBrush x:Key="FocusBorder" Color="#007FD4" />
    <!-- Tree node icon colours (match VS Code dark) -->
    <SolidColorBrush x:Key="TreeIconFg" Color="#75BEFF" />
  </Styles.Resources>

  <!-- ─── Window ─────────────────────────────────────────────── -->
  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource AppBg}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="FontFamily" Value="Segoe UI, Inter, -apple-system, sans-serif" />
    <Setter Property="FontSize" Value="13" />
  </Style>

  <!-- ─── Panels ─────────────────────────────────────────────── -->
  <Style Selector="Border.panel">
    <Setter Property="Background" Value="{DynamicResource PanelBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.card">
    <Setter Property="Background" Value="{DynamicResource PanelSoftBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Border.sidebar">
    <Setter Property="Background" Value="{DynamicResource SidebarBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
    <Setter Property="BorderThickness" Value="0,0,1,0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="Border.toolbar">
    <Setter Property="Background" Value="{DynamicResource SidebarBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="6,4" />
  </Style>

  <Style Selector="Border.statusbar">
    <Setter Property="Background" Value="{DynamicResource AccentBlue}" />
    <Setter Property="Padding" Value="8,3" />
  </Style>

  <Style Selector="Border.inline-info">
    <Setter Property="Background" Value="#1B3A4B" />
    <Setter Property="BorderBrush" Value="#007ACC" />
    <Setter Property="BorderThickness" Value="1,0,0,0" />
    <Setter Property="Padding" Value="10,6" />
  </Style>

  <!-- ─── Typography ─────────────────────────────────────────── -->
  <Style Selector="TextBlock.title">
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextBright}" />
  </Style>

  <Style Selector="TextBlock.subtitle">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="Padding" Value="12,8,12,4" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="FontSize" Value="11" />
  </Style>

  <Style Selector="TextBlock.statusbar-text">
    <Setter Property="Foreground" Value="White" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <!-- ─── Buttons ────────────────────────────────────────────── -->
  <Style Selector="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBg}" />
  </Style>

  <Style Selector="Button:pressed">
    <Setter Property="Background" Value="#37373D" />
  </Style>

  <Style Selector="Button.primary">
    <Setter Property="Background" Value="{DynamicResource AccentBlue}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="Padding" Value="14,5" />
  </Style>

  <Style Selector="Button.primary:pointerover">
    <Setter Property="Background" Value="#1177BB" />
  </Style>

  <Style Selector="Button.ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
  </Style>

  <Style Selector="Button.ghost:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBg}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <Style Selector="Button.danger">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource Danger}" />
  </Style>

  <Style Selector="Button.danger:pointerover">
    <Setter Property="Background" Value="#3A1D1D" />
  </Style>

  <Style Selector="Button.toolbar-btn">
    <Setter Property="Padding" Value="8,4" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="MinHeight" Value="26" />
  </Style>

  <Style Selector="Button.icon-btn">
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="MinHeight" Value="26" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.tab-close">
    <Setter Property="Padding" Value="4,2" />
    <Setter Property="MinWidth" Value="20" />
    <Setter Property="MinHeight" Value="20" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="CornerRadius" Value="3" />
  </Style>

  <Style Selector="Button.tab-close:pointerover">
    <Setter Property="Background" Value="#37373D" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <!-- ─── Inputs ─────────────────────────────────────────────── -->
  <Style Selector="TextBox">
    <Setter Property="Background" Value="{DynamicResource InputBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="Padding" Value="6,4" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <Style Selector="TextBox:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource FocusBorder}" />
  </Style>

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{DynamicResource InputBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="Padding" Value="6,3" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="{DynamicResource PanelSoftBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>

  <!-- ─── NumericUpDown ──────────────────────────────────────── -->
  <Style Selector="NumericUpDown">
    <Setter Property="Background" Value="{DynamicResource InputBg}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="MinHeight" Value="26" />
  </Style>
  <Style Selector="NumericUpDown /template/ ButtonSpinner">
    <Setter Property="Background" Value="{DynamicResource InputBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource InputBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>
  <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="Padding" Value="2" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="MinWidth" Value="20" />
  </Style>
  <Style Selector="NumericUpDown /template/ ButtonSpinner /template/ Button:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBg}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
  </Style>
  <Style Selector="NumericUpDown /template/ TextBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="4,2" />
  </Style>

  <!-- ─── DataGrid ───────────────────────────────────────────── -->
  <Style Selector="DataGrid">
    <Setter Property="Background" Value="{DynamicResource PanelBg}" />
    <Setter Property="BorderBrush" Value="{DynamicResource PanelBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="GridLinesVisibility" Value="Horizontal" />
    <Setter Property="HorizontalGridLinesBrush" Value="#2D2D30" />
    <Setter Property="VerticalGridLinesBrush" Value="#2D2D30" />
    <Setter Property="RowBackground" Value="Transparent" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- Selected row: very subtle so the current-cell indicator stands out -->
  <Style Selector="DataGridRow:selected /template/ Rectangle#BackgroundRectangle">
    <Setter Property="Opacity" Value="0.18" />
  </Style>

  <!-- Current (focused) cell: accent border on all sides + soft fill -->
  <Style Selector="DataGridCell:current">
    <Setter Property="Background" Value="#12304A" />
    <Setter Property="BorderBrush" Value="{DynamicResource AccentBlue}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>

  <!-- ─── TabControl ─────────────────────────────────────────── -->
  <Style Selector="TabControl">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl > TabItem">
    <Setter Property="Background" Value="{DynamicResource TabBarBg}" />
    <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    <Setter Property="Padding" Value="12,6" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="BorderThickness" Value="0,2,0,0" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="TabControl > TabItem:selected">
    <Setter Property="Background" Value="{DynamicResource TabActiveBg}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBright}" />
    <Setter Property="BorderBrush" Value="{DynamicResource TabActiveBorder}" />
  </Style>

  <Style Selector="TabControl > TabItem:pointerover">
    <Setter Property="Background" Value="{DynamicResource HoverBg}" />
  </Style>

  <!-- ─── TreeView ───────────────────────────────────────────── -->
  <Style Selector="TreeView">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Padding" Value="0,4,0,4" />
  </Style>

  <!-- Make the entire row the click / hover target -->
  <Style Selector="TreeViewItem">
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="MinHeight" Value="26" />
    <!-- Stretch the layout root so the full-width row is the target -->
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TreeViewItem /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="Transparent" />
    <!-- Ensure it fills the entire sidebar width -->
    <Setter Property="HorizontalAlignment" Value="Stretch" />
  </Style>

  <Style Selector="TreeViewItem:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource HoverBg}" />
  </Style>

  <Style Selector="TreeViewItem:selected /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="{DynamicResource SelectionBg}" />
  </Style>

  <Style Selector="TreeViewItem:selected:pointerover /template/ Border#PART_LayoutRoot">
    <Setter Property="Background" Value="#0F5A8B" />
  </Style>

  <!-- ─── Expander ───────────────────────────────────────────── -->
  <Style Selector="Expander">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <!-- ─── Separator ──────────────────────────────────────────── -->
  <Style Selector="Separator">
    <Setter Property="Background" Value="{DynamicResource PanelBorder}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Margin" Value="0,4" />
  </Style>

  <!-- ─── CheckBox ───────────────────────────────────────────── -->
  <Style Selector="CheckBox">
    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    <Setter Property="FontSize" Value="12" />
  </Style>

  <!-- ─── ScrollViewer ───────────────────────────────────────── -->
  <Style Selector="ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <!-- ─── ProgressBar ────────────────────────────────────────── -->
  <Style Selector="ProgressBar">
    <Setter Property="Foreground" Value="{DynamicResource AccentBlue}" />
    <Setter Property="Background" Value="{DynamicResource PanelBorder}" />
  </Style>

</Styles>
