<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DaTT.App.ViewModels"
             x:Class="DaTT.App.Views.ActiveConnectionsTabView"
             x:DataType="vm:ActiveConnectionsTabViewModel">

    <DockPanel>

        <!-- ─── Toolbar ──────────────────────────────────────────── -->
        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button Classes="toolbar-btn,primary" Content="Refresh" Command="{Binding RefreshCommand}" />
                <Button Classes="toolbar-btn,danger"
                        Content="Terminate"
                        Command="{Binding TerminateConnectionCommand}"
                        ToolTip.Tip="Terminate selected connection" />

                <Border Width="1" Background="#3E3E42" Margin="4,4" />

                <CheckBox Content="Auto" IsChecked="{Binding IsAutoRefreshEnabled}" VerticalAlignment="Center" FontSize="12" />

                <!-- amount stepper -->
                <Border Background="{DynamicResource InputBg}"
                        BorderBrush="{DynamicResource InputBorder}"
                        BorderThickness="1" CornerRadius="2"
                        VerticalAlignment="Center" Margin="4,0,2,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="−" Command="{Binding DecrementAmountCommand}"
                                Classes="toolbar-btn"
                                Padding="5,2" MinWidth="22" FontSize="14"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                        <TextBlock Text="{Binding IntervalAmount}"
                                   Foreground="{DynamicResource TextBright}"
                                   FontSize="13" FontWeight="SemiBold"
                                   MinWidth="26" TextAlignment="Center"
                                   VerticalAlignment="Center" Margin="2,0" />
                        <Button Content="+" Command="{Binding IncrementAmountCommand}"
                                Classes="toolbar-btn"
                                Padding="5,2" MinWidth="22" FontSize="14"
                                VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- unit selector -->
                <Border Background="{DynamicResource InputBg}"
                        BorderBrush="{DynamicResource InputBorder}"
                        BorderThickness="1" CornerRadius="2"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="0">
                        <Button Content="s"
                                Command="{Binding SetUnitCommand}" CommandParameter="s"
                                Classes="toolbar-btn"
                                Classes.primary="{Binding UnitIsSec}"
                                Padding="6,2" FontSize="12" />
                        <Button Content="min"
                                Command="{Binding SetUnitCommand}" CommandParameter="min"
                                Classes="toolbar-btn"
                                Classes.primary="{Binding UnitIsMin}"
                                Padding="6,2" FontSize="12" />
                        <Button Content="h"
                                Command="{Binding SetUnitCommand}" CommandParameter="h"
                                Classes="toolbar-btn"
                                Classes.primary="{Binding UnitIsHour}"
                                Padding="6,2" FontSize="12" />
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}" Classes="muted" VerticalAlignment="Center" Margin="8,0" />
            </StackPanel>
        </Border>

        <!-- ─── Error banner ─────────────────────────────────────── -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Danger}"
                   FontSize="12"
                   Margin="8,4"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <!-- ─── Connections grid ──────────────────────────────────── -->
        <DataGrid ItemsSource="{Binding Connections}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID / ID"  Binding="{Binding Id}"       Width="80" />
                <DataGridTextColumn Header="User"      Binding="{Binding User}"      Width="120" />
                <DataGridTextColumn Header="Host / IP" Binding="{Binding Host}"      Width="150" />
                <DataGridTextColumn Header="Database"  Binding="{Binding Database}"  Width="120" />
                <DataGridTextColumn Header="State"     Binding="{Binding State}"     Width="100" />
                <DataGridTextColumn Header="Duration"  Binding="{Binding Duration}"  Width="90" />
                <DataGridTextColumn Header="Query"     Binding="{Binding Query}"     Width="*" />
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>

</UserControl>
