<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DaTT.App.ViewModels"
        x:Class="DaTT.App.Views.CellExpandWindow"
        x:DataType="vm:CellExpandViewModel"
        Title="{Binding ColumnName}"
        Width="700" Height="480"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontWeight="SemiBold" FontSize="12" Text="{Binding ColumnName}" VerticalAlignment="Center" />
                <Border Background="#333" CornerRadius="3" Padding="6,2" IsVisible="{Binding IsJson}">
                    <TextBlock Text="JSON" FontSize="10" Foreground="{DynamicResource AccentGreen}" />
                </Border>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="toolbar">
            <Button Classes="ghost" Content="Close" HorizontalAlignment="Right" Click="OnCloseClicked" />
        </Border>

        <TextBox Text="{Binding FormattedContent}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 FontFamily="Consolas,Courier New,monospace"
                 FontSize="12"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="8"
                 TextWrapping="Wrap" />

    </DockPanel>
</Window>
