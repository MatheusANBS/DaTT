<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DaTT.App.ViewModels"
        x:Class="DaTT.App.Views.CellExpandWindow"
        x:DataType="vm:CellExpandViewModel"
        Title="{Binding ColumnName}"
        Icon="/Assets/IconDaTT.ico"
        Width="700" Height="480"
        MinWidth="400" MinHeight="300"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontWeight="SemiBold" FontSize="12" Text="{Binding ColumnName}" VerticalAlignment="Center" />
                <Border Background="#333" CornerRadius="3" Padding="6,2" IsVisible="{Binding IsJson}">
                    <TextBlock Text="JSON" FontSize="10" Foreground="{DynamicResource AccentGreen}" />
                </Border>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="toolbar">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Orientation="Horizontal" Spacing="4"
                            IsVisible="{Binding IsJson}" VerticalAlignment="Center">
                    <TextBlock Text="Format:" FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextMuted}" />
                    <RadioButton Content="Flat" GroupName="JsonModeExpand"
                                 IsChecked="{Binding IsFlat}"
                                 Click="OnFlatClicked"
                                 VerticalAlignment="Center" FontSize="11" />
                    <RadioButton Content="Vertical" GroupName="JsonModeExpand"
                                 IsChecked="{Binding IsVertical}"
                                 Click="OnVerticalClicked"
                                 VerticalAlignment="Center" FontSize="11" />
                </StackPanel>
                <Button Grid.Column="1" Classes="ghost" Content="Close" Click="OnCloseClicked" />
            </Grid>
        </Border>

        <TextBox Text="{Binding DisplayContent}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 FontFamily="Consolas,Courier New,monospace"
                 FontSize="12"
                 Background="Transparent"
                 BorderThickness="0"
                 Padding="8"
                 TextWrapping="Wrap"
                 VerticalAlignment="Stretch"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 ScrollViewer.IsScrollChainingEnabled="False" />

    </DockPanel>
</Window>
