<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DaTT.App.ViewModels"
             xmlns:mi="using:Material.Icons.Avalonia"
             x:Class="DaTT.App.Views.DataGridTabView"
             x:DataType="vm:DataGridTabViewModel">

    <DockPanel>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Classes="toolbar-btn" Command="{Binding InsertRowCommand}" ToolTip.Tip="Insert a new row">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="TablePlus" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Insert" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Classes="toolbar-btn,primary" Content="Save" Command="{Binding SavePendingChangesCommand}" IsEnabled="{Binding HasPendingChanges}" ToolTip.Tip="Save pending edits" />
                <Button Classes="toolbar-btn,ghost" Content="Refresh" Command="{Binding RefreshTableCommand}" ToolTip.Tip="Reload current page" />
                <Border Width="1" Background="#3E3E42" Margin="4,4" />
                <Button Classes="toolbar-btn,ghost" Content="Export" Command="{Binding ExportDataCommand}" ToolTip.Tip="Export rows" />
                <ComboBox Width="72" ItemsSource="{Binding ExportFormats}" SelectedItem="{Binding SelectedExportFormat}" />
                <CheckBox Content="Full" IsChecked="{Binding ExportFullTable}" VerticalAlignment="Center" FontSize="11" />
                <Border Width="1" Background="#3E3E42" Margin="4,4" />
                <Button Classes="toolbar-btn,ghost" Content="Import SQL" Command="{Binding ImportSqlCommand}" ToolTip.Tip="Import SQL script" />
                <Button Classes="toolbar-btn,ghost" Click="OnReorderColumnsClick" ToolTip.Tip="Drag-and-drop column order">
                    <Button.Content>
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <mi:MaterialIcon Kind="ViewList" Width="14" Height="14" VerticalAlignment="Center" />
                            <TextBlock Text="Reorder" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button.Content>
                </Button>
                <Button Classes="toolbar-btn,ghost" Content="Stop Edit" Command="{Binding DisableInlineEditCommand}" IsVisible="{Binding IsInlineEditMode}" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <ComboBox Width="140"
                          ItemsSource="{Binding FilterColumns}"
                          SelectedItem="{Binding FilterColumn, Mode=TwoWay}"
                          PlaceholderText="All columns" />
                <TextBox Width="200" Watermark="Search value..." Text="{Binding FilterValue}">
                    <TextBox.KeyBindings>
                        <KeyBinding Gesture="Enter" Command="{Binding ApplyFilterCommand}" />
                    </TextBox.KeyBindings>
                </TextBox>
                <Button Classes="toolbar-btn,primary" Content="Apply" Command="{Binding ApplyFilterCommand}" />
                <Button Classes="toolbar-btn" Command="{Binding ClearFilterCommand}" ToolTip.Tip="Clear filter">
                    <Button.Content><mi:MaterialIcon Kind="FilterRemove" Width="14" Height="14" /></Button.Content>
                </Button>
                <Border Width="1" Background="#3E3E42" Margin="4,4" />
                <Button Classes="icon-btn" Command="{Binding PreviousPageCommand}" ToolTip.Tip="Previous page">
                    <Button.Content><mi:MaterialIcon Kind="ChevronLeft" Width="14" Height="14" /></Button.Content>
                </Button>
                <TextBlock VerticalAlignment="Center" FontSize="12" Margin="4,0">
                    <Run Text="{Binding CurrentPage}" />
                    <Run Text=" / " />
                    <Run Text="{Binding TotalPages}" />
                </TextBlock>
                <Button Classes="icon-btn" Command="{Binding NextPageCommand}" ToolTip.Tip="Next page">
                    <Button.Content><mi:MaterialIcon Kind="ChevronRight" Width="14" Height="14" /></Button.Content>
                </Button>
                <TextBlock VerticalAlignment="Center" Text="{Binding TotalRows, StringFormat='{}{0} rows'}" Classes="muted" Margin="6,0,0,0" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Classes="inline-info" IsVisible="{Binding IsInlineStatusVisible}">
            <TextBlock Text="{Binding InlineEditStatus}" Foreground="{DynamicResource AccentGreen}" FontSize="11" />
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding ErrorMessage}"
                   Foreground="{DynamicResource Danger}"
                   FontSize="12"
                   Margin="8,4"
                   IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="2" />

        <DataGrid x:Name="ResultGrid"
                  ItemsSource="{Binding Rows}"
                  SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                  SelectionMode="Extended"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserSortColumns="False"
                  IsReadOnly="{Binding IsGridReadOnly}">
            <DataGrid.ContextMenu>
                <ContextMenu x:Name="RowContextMenu">
                    <MenuItem Header="Edit Row..." x:Name="MenuEditRow" />
                    <MenuItem Header="Duplicate Row" x:Name="MenuDuplicateRow" />
                    <MenuItem Header="Delete Row" x:Name="MenuDeleteRow" />
                    <Separator />
                    <MenuItem Header="Copy Row" x:Name="MenuCopyRow" />
                    <Separator />
                    <MenuItem Header="Set Values..." x:Name="MenuSetValues" />
                </ContextMenu>
            </DataGrid.ContextMenu>
        </DataGrid>

    </DockPanel>

</UserControl>
