<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DaTT.App.ViewModels"
        x:Class="DaTT.App.Views.EditRowWindow"
        x:DataType="vm:EditRowViewModel"
        Title="{Binding Mode}"
        Icon="/Assets/IconDaTT.ico"
        Width="640" Height="640"
        MinWidth="480" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock FontSize="12" FontWeight="SemiBold" Text="{Binding TableName}" VerticalAlignment="Center" />
                <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" Text="{Binding Mode, StringFormat='({0})'}" VerticalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                <Button Classes="primary" Content="Save" Click="OnSaveClicked" MinWidth="80" />
                <Button Classes="ghost" Content="Cancel" Click="OnCancelClicked" MinWidth="80" />
            </StackPanel>
        </Border>

        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Fields}" Margin="8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:FieldEdit">
                        <Grid ColumnDefinitions="Auto,8,*" Margin="0,4">
                            <StackPanel Grid.Column="0" VerticalAlignment="Top" MinWidth="120" MaxWidth="180" Margin="0,6,0,0">
                                <TextBlock Text="{Binding ColumnName}" FontSize="12" TextWrapping="Wrap"
                                           FontWeight="{Binding IsPrimaryKey, Converter={x:Static vm:BoolToFontWeightConverter.Instance}}" />
                                <TextBlock Text="{Binding DataType}" FontSize="10" TextWrapping="Wrap" Foreground="{DynamicResource TextMuted}" />
                            </StackPanel>
                            <Panel Grid.Column="2" VerticalAlignment="Center">
                                <TextBox Text="{Binding Value}"
                                         IsVisible="{Binding IsTextInput}"
                                         IsReadOnly="{Binding IsReadOnly}"
                                         Opacity="{Binding IsReadOnly, Converter={x:Static vm:BoolToOpacityConverter.Instance}}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="36"
                                         MaxHeight="{Binding TextInputMaxHeight}" />
                                <StackPanel Orientation="Horizontal" Spacing="4"
                                            IsVisible="{Binding IsDateTimeField}">
                                    <CalendarDatePicker SelectedDate="{Binding DatePart, Mode=TwoWay}"
                                                        IsEnabled="{Binding IsReadOnly, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                                                        Width="180" FontSize="12" />
                                    <TimePicker SelectedTime="{Binding TimePart, Mode=TwoWay}"
                                                IsEnabled="{Binding IsReadOnly, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                                                Width="160" FontSize="12" />
                                </StackPanel>
                                <CalendarDatePicker SelectedDate="{Binding DatePart, Mode=TwoWay}"
                                                    IsVisible="{Binding IsDateOnlyField}"
                                                    IsEnabled="{Binding IsReadOnly, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                                                    Width="180" FontSize="12" />
                                <TimePicker SelectedTime="{Binding TimePart, Mode=TwoWay}"
                                            IsVisible="{Binding IsTimeOnlyField}"
                                            IsEnabled="{Binding IsReadOnly, Converter={x:Static vm:InverseBoolConverter.Instance}}"
                                            Width="160" FontSize="12" />
                            </Panel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</Window>
