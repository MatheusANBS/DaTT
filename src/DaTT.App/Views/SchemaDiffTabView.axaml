<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DaTT.App.ViewModels"
             x:Class="DaTT.App.Views.SchemaDiffTabView"
             x:DataType="vm:SchemaDiffTabViewModel">

    <DockPanel>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock VerticalAlignment="Center" Text="Source" Classes="muted" Margin="4,0" />
                <ComboBox Width="200" ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedSourceTable}" />
                <TextBlock VerticalAlignment="Center" Text="Dest" Classes="muted" Margin="4,0" />
                <ComboBox Width="200" ItemsSource="{Binding Tables}" SelectedItem="{Binding SelectedDestinationTable}" />
                <CheckBox VerticalAlignment="Center" Content="Drops" IsChecked="{Binding IncludeDrops}" FontSize="12" />
                <Border Width="1" Background="#3E3E42" Margin="4,4" />
                <Button Classes="toolbar-btn,primary" Content="Generate Diff" Command="{Binding GenerateDiffCommand}" />
                <Button Classes="toolbar-btn,danger" Content="Apply All" Command="{Binding ApplyAllCommand}" />
                <TextBlock VerticalAlignment="Center" Text="{Binding ResultMessage}" Classes="muted" Margin="8,0" />
            </StackPanel>
        </Border>

        <Grid RowDefinitions="*,Auto,Auto">
            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding DiffItems}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserResizeColumns="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Kind" Binding="{Binding Kind}" Width="140" />
                    <DataGridTextColumn Header="Object" Binding="{Binding ObjectName}" Width="200" />
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" ResizeDirection="Rows" Height="4" Background="Transparent" />

            <TextBox Grid.Row="2"
                     Text="{Binding GeneratedSql}"
                     AcceptsReturn="True"
                     Height="140"
                     FontFamily="Consolas,Courier New,Monospace"
                     FontSize="12"
                     IsReadOnly="True"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8" />
        </Grid>

    </DockPanel>

</UserControl>
