<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DaTT.App.ViewModels"
        x:Class="DaTT.App.Views.SetValuesWindow"
        x:DataType="vm:SetValuesViewModel"
        Title="Set Values"
        Icon="/Assets/IconDaTT.ico"
        Width="480" Height="560"
        MinWidth="380" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <DockPanel>

        <Border DockPanel.Dock="Top" Classes="toolbar">
            <TextBlock Text="Select columns and choose target value" FontSize="12" VerticalAlignment="Center" />
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="toolbar">
            <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                <Button Classes="primary" Content="Apply" Click="OnApplyClicked" MinWidth="80" />
                <Button Classes="ghost" Content="Cancel" Click="OnCancelClicked" MinWidth="80" />
            </StackPanel>
        </Border>

        <Grid RowDefinitions="Auto,8,*" Margin="12,8">

            <!-- Value Mode Selection -->
            <Border Grid.Row="0" Background="#252526" CornerRadius="4" Padding="12,8">
                <StackPanel Spacing="6">
                    <TextBlock Text="Set selected columns to:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <RadioButton Content="NULL" IsChecked="{Binding IsNullMode}" />
                        <RadioButton Content="Empty string" IsChecked="{Binding IsEmptyMode}" />
                        <RadioButton Content="Custom value" IsChecked="{Binding IsCustomMode}" />
                    </StackPanel>
                    <TextBox Watermark="Custom value..."
                             Text="{Binding CustomValue}"
                             IsVisible="{Binding IsCustomValueVisible}"
                             Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- Column Checkboxes -->
            <Border Grid.Row="2" Background="#1E1E1E" CornerRadius="4" Padding="4">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Classes="section-title" Text="COLUMNS" Margin="8,4,0,4" />
                    <ScrollViewer>
                        <ItemsControl ItemsSource="{Binding ColumnItems}" Margin="4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SetValueColumnItem">
                                    <Border Padding="6,3" CornerRadius="3" Margin="0,1">
                                        <Grid ColumnDefinitions="Auto,8,*,Auto">
                                            <CheckBox Grid.Column="0"
                                                      IsChecked="{Binding IsChecked}"
                                                      IsEnabled="{Binding IsEnabled}"
                                                      VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ColumnName}"
                                                       FontSize="12"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding DataType}"
                                                       FontSize="10"
                                                       Foreground="{DynamicResource TextMuted}"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

        </Grid>

    </DockPanel>
</Window>
