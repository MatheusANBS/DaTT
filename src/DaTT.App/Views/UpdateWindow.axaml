<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="DaTT.App.Views.UpdateWindow"
        Title="Update Available"
        Width="480" Height="370"
        MinWidth="440" MinHeight="340"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        ExtendClientAreaToDecorationsHint="False">

    <Border Padding="28">
        <Grid RowDefinitions="Auto,Auto,*,Auto,Auto">

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="↓" FontSize="28" Margin="0,0,14,0" Foreground="#22C55E" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="New version available!" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="VersionText" FontSize="12" Opacity="0.6" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Release Notes label -->
            <TextBlock Grid.Row="1" Text="Release Notes" FontSize="13" FontWeight="SemiBold" Opacity="0.7" Margin="0,0,0,6"/>

            <!-- Release Notes content -->
            <Border Grid.Row="2" Background="#2A2A3E" CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ChangelogText" TextWrapping="Wrap" FontSize="12" Opacity="0.85" LineHeight="20"/>
                </ScrollViewer>
            </Border>

            <!-- Download Progress (hidden initially) -->
            <StackPanel Grid.Row="3" x:Name="ProgressPanel" IsVisible="False" Margin="0,0,0,16">
                <Grid Margin="0,0,0,6">
                    <TextBlock x:Name="ProgressStatusText" Text="Downloading..." FontSize="12" Opacity="0.7"/>
                    <TextBlock x:Name="ProgressPercentText" Text="0%" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Right" Opacity="0.7"/>
                </Grid>
                <ProgressBar x:Name="DownloadProgress" Height="6" Minimum="0" Maximum="100" Value="0"
                             Foreground="#22C55E"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button x:Name="CancelButton" Content="Later" Click="Cancel_Click"
                        Padding="24,8" MinWidth="100"/>
                <Button x:Name="UpdateButton" Content="Update &amp; Restart" Click="Update_Click"
                        Padding="24,8" MinWidth="150" Background="#22C55E" Foreground="White"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>
